# Variables de entorno para EduApoyos

ASPNETCORE_ENVIRONMENT=Production

# Red Docker del contenedor PostgreSQL (tabla Network del contenedor de la DB).
# Ejemplo: demofreddyvargas-demofreddyvargas-anjpr5 (o el nombre exacto que muestre el panel)
POSTGRES_NETWORK=NOMBRE_EXACTO_DE_LA_RED_DEL_POSTGRES

# Host = alias/nombre interno del servicio PostgreSQL (no la red).
CONNECTION_STRING=Host=demofreddyvargas-demofreddyvargas-anjpr5;Port=5432;Database=eduapoyos;Username=root;Password=TU_PASSWORD

JWT_ISSUER=EduApoyos
JWT_AUDIENCE=EduApoyos
JWT_KEY=cambia-esta-clave-por-un-secreto-de-32-caracteres
JWT_EXPIRE_MINUTES=120

FRONTEND_ORIGIN=http://localhost:8080

API_PORT=5000
FRONTEND_PORT=8080
