# Variables de entorno para EduApoyos

ASPNETCORE_ENVIRONMENT=Production

# Host = nombre del servicio PostgreSQL (columna Aliases del contenedor DB)
CONNECTION_STRING=Host=postgres;Port=5432;Database=educapoyos;Username=educapoyos;Password=educapoyos

JWT_ISSUER=EduApoyos
JWT_AUDIENCE=EduApoyos
JWT_KEY=cambia-esta-clave-por-un-secreto-de-32-caracteres
JWT_EXPIRE_MINUTES=120

FRONTEND_ORIGIN=http://localhost:8080

API_PORT=5000
FRONTEND_PORT=8080
