# Variables de entorno para EduApoyos

ASPNETCORE_ENVIRONMENT=Production

# Apunta a TU PostgreSQL (la que ya tienes corriendo).
# Formato: Host=...;Port=5432;Database=...;Username=...;Password=...
CONNECTION_STRING=Host=TU_HOST_POSTGRES;Port=5432;Database=eduapoyos;Username=root;Password=TU_PASSWORD

JWT_ISSUER=EduApoyos
JWT_AUDIENCE=EduApoyos
JWT_KEY=cambia-esta-clave-por-un-secreto-de-32-caracteres
JWT_EXPIRE_MINUTES=120

FRONTEND_ORIGIN=http://localhost:8080

API_PORT=5000
FRONTEND_PORT=8080
